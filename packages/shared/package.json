{
	"name": "@orbit/shared",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js",
			"default": "./dist/*.js"
		}
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"typescript": "6.0.3"
	}
}
