{
	"compilerOptions": {
		"target": "ES2022",
		"lib": [
			"ES2022",
		],
		"module": "NodeNext",
		"moduleResolution": "nodenext",
		"skipLibCheck": true,
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": "./src"
	},
	"include": [
		"src"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}