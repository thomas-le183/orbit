{
  "name": "orbit",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "predev": "for p in 8000 5173; do lsof -ti :$p | xargs -r kill -9; done || true",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "stripe:listen": "stripe listen --forward-to localhost:8000/api/auth/stripe/webhook",
    "docker:up": "docker compose -f docker-compose-local.yml up -d",
    "docker:down": "docker compose -f docker-compose-local.yml down"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "turbo": "^2.10.2",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.0.9"
}