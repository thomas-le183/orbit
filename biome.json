{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/src/**/*",
			"**/.vscode/**/*",
			"**/index.html",
			"**/vite.config.ts",
			"!**/routeTree.gen.ts",
			"!**/src/styles.css"
		]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"a11y": "off",
			"security": "off",
			"suspicious": "off",
			"correctness": {
				"noChildrenProp": "off"
			}
		}
	},
	"assist": {
		"enabled": true
	},
	"json": {
		"formatter": {
			"enabled": false
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}