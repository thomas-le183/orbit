# API-specific settings only.
# Shared infra vars (DB, Redis, RabbitMQ, Storage) live in the root .env
# and are auto-loaded via ConfigModule's envFilePath fallback.

# App Settings
PORT=8000

# CORS settings
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3100"

# Stripe Settings
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Web base URL (for Stripe redirect URLs)
WEB_BASE_URL="http://localhost:3000"

# Maximum file upload limit
FILE_SIZE_LIMIT=5242880

# API key rate limit
API_KEY_RATE_LIMIT="60/minute"

# Auth Settings
BETTER_AUTH_URL="http://localhost:8000"
COOKIE_DOMAIN="localhost"
