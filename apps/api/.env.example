# App Settings
PORT=8000

# CORS settings
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3100"

# Database Settings
POSTGRES_USER="orbit"
POSTGRES_PASSWORD="orbit"
POSTGRES_HOST="orbit-db"
POSTGRES_DB="orbit"
POSTGRES_PORT="5432"

DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Redis Settings
REDIS_HOST="orbit-redis"
REDIS_PORT="6379"
REDIS_PASSWORD="orbit"

# RabbitMQ Settings
RABBITMQ_HOST="orbit-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="orbit"
RABBITMQ_PASSWORD="orbit"
RABBITMQ_VHOST="orbit"

# Stripe Settings
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# Web base URL (for Stripe redirect URLs)
WEB_BASE_URL="http://localhost:3000"

# Maximum file upload limit
FILE_SIZE_LIMIT=5242880

# API key rate limit
API_KEY_RATE_LIMIT="60/minute"