{
	"name": "api",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"dev": "nest start --watch",
		"start": "nest start",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"typecheck": "tsc --noEmit",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"db:seed": "bun src/db/seed.ts init",
		"db:seed:dev": "bun src/db/seed.ts dev",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@better-auth/stripe": "^1.5.6",
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.0.1",
		"@nestjs/platform-express": "^11.0.1",
		"@orbit/shared": "workspace:*",
		"better-auth": "^1.5.6",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.3.1",
		"dotenv-expand": "^12.0.3",
		"drizzle-orm": "^0.45.2",
		"pg": "^8.20.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"stripe": "^20.4.1"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.0.0",
		"@types/pg": "^8.20.0",
		"@types/supertest": "^7.0.0",
		"drizzle-kit": "^0.31.10",
		"jest": "^30.0.0",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}