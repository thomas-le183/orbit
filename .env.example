# Shared infra settings — consumed by docker-compose AND by apps/api
# (apps/api's ConfigModule reads this file as a fallback after apps/api/.env)

# Database Settings
POSTGRES_USER="orbit"
POSTGRES_PASSWORD="orbit"
POSTGRES_DB="orbit-db"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5433"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Redis Settings
REDIS_HOST="orbit-redis"
REDIS_PORT="6379"
REDIS_PASSWORD="orbit"

# RabbitMQ Settings
RABBITMQ_HOST="orbit-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="orbit"
RABBITMQ_PASSWORD="orbit"
RABBITMQ_VHOST="orbit"

# Storage (S3-compatible, RustFS for local dev)
STORAGE_HOST="localhost"
STORAGE_PORT="9000"
STORAGE_ENDPOINT="http://${STORAGE_HOST}:${STORAGE_PORT}"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY="rustfsadmin"
STORAGE_SECRET_KEY="rustfsadmin"
STORAGE_BUCKET="orbit"
STORAGE_FORCE_PATH_STYLE="true"
