
# Database Settings
POSTGRES_USER="orbit"
POSTGRES_PASSWORD="orbit"
POSTGRES_DB="orbit"
POSTGRES_HOST="orbit-db"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql://orbit:orbit@localhost:5433/orbit"

# Redis Settings
REDIS_HOST="orbit-redis"
REDIS_PORT="6379"
REDIS_PASSWORD="orbit"

# RabbitMQ Settings
RABBITMQ_HOST="orbit-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="orbit"
RABBITMQ_PASSWORD="orbit"
RABBITMQ_VHOST="orbit"

# Auth Settings
BETTER_AUTH_SECRET="change-me-to-a-random-secret"
BETTER_AUTH_URL="http://localhost:8000"
COOKIE_DOMAIN="localhost"

# Maximum file upload limit
FILE_SIZE_LIMIT=5242880

# API key rate limit
API_KEY_RATE_LIMIT="60/minute"